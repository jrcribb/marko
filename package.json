{
  "name": "marko-project",
  "private": true,
  "scripts": {
    "@ci:build": "pnpm run build",
    "@ci:lint": "eslint --format unix . && prettier . --check --with-node-modules --log-level=warn",
    "@ci:release": "pnpm run build && node scripts/pkg-override && changeset publish && pnpm run @ci:release-alias && node scripts/pkg-override && pnpm install --frozen-lockfile",
    "@ci:release-alias": "node -r ~ts scripts/publish-alias.ts",
    "@ci:test": "cross-env NODE_OPTIONS=\"--max-old-space-size=8192 --max-semi-space-size=128\" MARKO_DEBUG=1 c8 pnpm run test:parallel",
    "@ci:test:fast": "cross-env NODE_OPTIONS=\"--max-old-space-size=8192 --max-semi-space-size=128\" MARKO_DEBUG=1 pnpm run test:parallel",
    "@ci:version": "pnpm run build && pnpm run format && changeset version && pnpm install --lockfile-only",
    "audit": "pnpm audit --prod",
    "build": "pnpm -r --if-present run build && pnpm run build:types",
    "build:sizes": "node -r ~ts scripts/sizes",
    "build:types": "tsc -b tsconfig.build.json",
    "change": "changeset add",
    "compile": "node -r ~ts scripts/inspect-compiled-output.ts",
    "format": "eslint --format unix --fix .; prettier . --write --with-node-modules --log-level=warn",
    "lint": "eslint --format unix . && prettier . --check --with-node-modules --log-level=warn",
    "prepare": "husky && pnpm --filter @marko/compiler run build-babel-types",
    "report": "open ./coverage/lcov-report/index.html",
    "test": "mocha",
    "test:parallel": "node scripts/test-parallel.js",
    "test:update": "UPDATE_EXPECTATIONS=1 mocha"
  },
  "devDependencies": {
    "@babel/cli": "^7.28.6",
    "@babel/code-frame": "^7.29.0",
    "@babel/core": "^7.29.0",
    "@babel/generator": "^7.29.1",
    "@babel/parser": "^7.29.3",
    "@babel/plugin-syntax-typescript": "^7.28.6",
    "@babel/plugin-transform-export-namespace-from": "^7.29.7",
    "@babel/plugin-transform-modules-commonjs": "^7.28.6",
    "@babel/plugin-transform-typescript": "^7.28.6",
    "@babel/preset-env": "^7.29.5",
    "@babel/preset-typescript": "^7.28.5",
    "@babel/register": "^7.29.3",
    "@babel/traverse": "^7.29.0",
    "@babel/types": "^7.29.0",
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@ebay/browserslist-config": "^2.15.0",
    "@eslint/js": "^10.0.1",
    "@jridgewell/sourcemap-codec": "^1.5.5",
    "@marko/compiler": "workspace:*",
    "@types/babel__code-frame": "^7.27.0",
    "@types/babel__core": "^7.20.5",
    "@types/babel__generator": "^7.27.0",
    "@types/babel__traverse": "^7.28.0",
    "@types/js-beautify": "^1.14.3",
    "@types/jsdom": "^28.0.3",
    "@types/mocha": "^10.0.10",
    "@types/node": "^26.1.0",
    "babel-plugin-minprops": "^2.0.1",
    "bluebird": "^3.7.2",
    "c8": "^11.0.0",
    "chai": "^4.4.1",
    "cross-env": "^10.1.0",
    "diffable-html": "^6.0.1",
    "eslint": "^10.6.0",
    "eslint-formatter-unix": "^9.0.1",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "express": "^5.2.1",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "js-beautify": "^2.0.3",
    "jsdom": "^29.1.1",
    "jsdom-context-require": "^5.2.8",
    "kleur": "^4.1.5",
    "lint-staged": "^17.0.8",
    "mocha": "^11.7.6",
    "mocha-autotest": "^1.1.3",
    "prettier": "^3.9.4",
    "prettier-plugin-packagejson": "^3.0.2",
    "pretty-format": "^30.4.1",
    "resolve-sync": "^1.2.0",
    "rolldown": "^1.1.4",
    "table": "^6.9.0",
    "through": "^2.3.8",
    "tiny-glob": "^0.2.9",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0",
    "~ts": "file:scripts/babel-register"
  },
  "packageManager": "pnpm@11.15.1"
}
